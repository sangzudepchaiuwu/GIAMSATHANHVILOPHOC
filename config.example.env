# Classroom Behavior Monitoring System - Configuration File
# Sao chép file này thành .env.local và điền thông tin của bạn

# ===== TELEGRAM BOT CONFIGURATION =====
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Lấy từ @userinfobot trên Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# ===== YOLO MODEL CONFIGURATION =====
# Đường dẫn tới file model weights
MODEL_PATH=classroom_behavior_finetune-20260523T202145Z-3-001/classroom_behavior_finetune/weights/best.pt

# Confidence threshold (0-1) - giảm = phát hiện nhiều hơn
YOLO_CONFIDENCE=0.75

# ===== ALERT CONFIGURATION =====
# Số lượng học sinh tối thiểu để kích hoạt cảnh báo
ALERT_SLEEPING_THRESHOLD=3
ALERT_PHONE_THRESHOLD=3

# Thời gian chờ giữa 2 lần cảnh báo (giây)
ALERT_COOLDOWN=60

# ===== FLASK SERVER CONFIGURATION =====
# Host để chạy server
FLASK_HOST=0.0.0.0

# Port để chạy server
FLASK_PORT=5000

# Debug mode (True/False)
FLASK_DEBUG=True

# ===== VIDEO UPLOAD CONFIGURATION =====
# Thư mục lưu trữ video
UPLOAD_FOLDER=static/uploads/

# Kích thước file upload tối đa (MB)
MAX_UPLOAD_SIZE=500

# ===== CAMERA CONFIGURATION =====
# Index webcam mặc định (0 = webcam chính)
DEFAULT_CAMERA_INDEX=0

# FPS video stream
VIDEO_FPS=30

# ===== LOGGING CONFIGURATION =====
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Đường dẫn file log
LOG_FILE=logs/app.log
